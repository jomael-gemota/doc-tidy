# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=doc-tidy

# Server
PORT=3001
NODE_ENV=development

# CORS allowed origin
# Development:  http://localhost:5173
# Production:   https://your-app.railway.app  (or * to allow all)
CLIENT_ORIGIN=http://localhost:5173

# ─── Correction embeddings ───────────────────────────────────────────────────
# Used to index user corrections so similar future documents retrieve them as
# few-shot examples. If unset, corrections are still stored but not retrievable
# until re-embedded. Use the SAME model as the worker so vectors are comparable.
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
