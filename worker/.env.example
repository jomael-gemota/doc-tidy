# ─── LLM backend ─────────────────────────────────────────────────────────────
#
# Option A — Local Ollama (default)
#   HERMES_BASE_URL=http://localhost:11434/v1
#   HERMES_MODEL=hermes3
#   HERMES_API_KEY=ollama
#
# Option B — OpenAI API (leave HERMES_BASE_URL unset or point to OpenAI)
#   HERMES_BASE_URL=          ← leave blank to use OpenAI's default endpoint
#   HERMES_MODEL=gpt-5.5      ← or gpt-4o, gpt-4o-mini, etc.
#   HERMES_API_KEY=sk-...     ← your real OpenAI API key
#
HERMES_BASE_URL=http://localhost:11434/v1
HERMES_MODEL=hermes3
HERMES_API_KEY=ollama

# Optional tuning — defaults shown.
# MAX_DOCUMENT_CHARS=12000   # Truncate document text sent to the model
# REQUEST_TIMEOUT=90         # HTTP timeout in seconds for the Hermes call
# MAX_TOKENS=2048            # Maximum tokens the model may generate

# ─── Tidy-voiced narration (reasoning panel) ─────────────────────────────────
# The pipeline narrates each step as Tidy talking to the user. Phrasing is
# generated dynamically with a small OpenAI model when OPENAI_API_KEY is set;
# otherwise Tidy-voiced static fallbacks are used (no OpenAI calls).
# This is separate from HERMES_API_KEY so document parsing can stay on a local
# backend while narration uses OpenAI.
# OPENAI_API_KEY=sk-...        # Real OpenAI key, used only for narration
# NARRATION_ENABLED=true       # Set false to force static fallbacks
# NARRATION_MODEL=gpt-4o-mini  # Small/fast model for narration
# NARRATION_TIMEOUT=15         # Seconds before a narration call falls back
# NARRATION_MAX_TOKENS=60      # Keep each narrated line short

# ─── MongoDB (same URI as the server) ────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=doc-tidy

# ─── Express Server WebSocket URL ────────────────────────────────────────────
# Development: ws://localhost:3001/ws
# Production:  wss://your-railway-domain.railway.app/ws
SERVER_WS_URL=ws://localhost:3001/ws
