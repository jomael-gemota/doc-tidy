# ─── Hermes Agent (running locally on this Ubuntu machine) ───────────────────
#
# HERMES_BASE_URL  — OpenAI-compatible endpoint your Hermes server exposes.
#   Common values:
#     http://localhost:8080/v1   (llama.cpp server)
#     http://localhost:1234/v1   (LM Studio)
#     http://localhost:11434/v1  (Ollama OpenAI-compat endpoint)
#
# HERMES_MODEL     — Model name as registered in your Hermes server.
#   Common values:  hermes3  |  nous-hermes-3  |  hermes-2-pro
#
# HERMES_API_KEY   — Most local servers do not need a real key.
#                    Leave the placeholder unless your server requires auth.
#
HERMES_BASE_URL=http://localhost:11434/v1
HERMES_MODEL=hermes3
HERMES_API_KEY=ollama

# Optional tuning — defaults shown.
# MAX_DOCUMENT_CHARS=12000   # Truncate document text sent to the model
# REQUEST_TIMEOUT=90         # HTTP timeout in seconds for the Hermes call
# MAX_TOKENS=2048            # Maximum tokens the model may generate

# ─── MongoDB (same URI as the server) ────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=doc-tidy

# ─── Express Server WebSocket URL ────────────────────────────────────────────
# Development: ws://localhost:3001/ws
# Production:  wss://your-railway-domain.railway.app/ws
SERVER_WS_URL=ws://localhost:3001/ws
